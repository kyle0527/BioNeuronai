# BioNeuronAI 環境變數設定
# 複製此文件為 .env 並填入實際值：  cp .env.example .env
# 所有金鑰透過 os.getenv() 讀取，禁止硬編碼至程式碼

# ==============================================
# Binance API
# 測試網申請: https://testnet.binancefuture.com
# 正式網申請: https://www.binance.com
# ==============================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# true = 測試網（虛擬資金，預設）⚠️ 建議先在測試網驗證
# false = 正式網（真實資金）⚠️ 謹慎操作
BINANCE_TESTNET=true

# ==============================================
# 新聞資料來源
# 免費方案直接填 free，有 token 可填入以提升速率限制
# 申請: https://cryptopanic.com/developers/api/
# ==============================================
CRYPTOPANIC_API_TOKEN=free

# ==============================================
# 選填：FastAPI 伺服器設定
# ==============================================
# API_HOST=0.0.0.0
# API_PORT=8000

# ==============================================
# 選填：交易對與槓桿預設值
# （可在 config/trading_config.py 中覆寫）
# ==============================================
# SYMBOL=BTCUSDT
# LEVERAGE=10
