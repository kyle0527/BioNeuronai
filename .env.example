# BioNeuronAI 虛擬貨幣交易系統環境變數配置
# 複製此文件為 .env 並填入實際的 API 密鑰

# ==============================================
# Binance API 配置
# ==============================================

# Binance API 密鑰（從 Binance 獲取）
# 測試網: https://testnet.binancefuture.com
# 正式網: https://www.binance.com
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 使用測試網（推薦新手使用 True）
# True = 測試網（虛擬資金）
# False = 正式網（真實資金）⚠️
USE_TESTNET=True

# ==============================================
# 交易配置
# ==============================================

# 自動交易開關（⚠️ 謹慎開啟）
AUTO_TRADE_ENABLED=False

# 使用策略融合系統（推薦）
USE_STRATEGY_FUSION=True

# 槓桿倍數（1-125）
LEVERAGE=1

# 最大單次交易金額（USDT）
MAX_TRADE_AMOUNT=100.0

# 最大持倉數量
MAX_POSITIONS=3

# ==============================================
# 風險管理
# ==============================================

# 單筆交易最大風險百分比（0.02 = 2%）
MAX_RISK_PER_TRADE=0.02

# 止損比例（0.02 = 2%）
STOP_LOSS_PERCENTAGE=0.02

# 止盈比例（0.03 = 3%）
TAKE_PROFIT_PERCENTAGE=0.03

# 最大回撤比例（0.10 = 10%）
MAX_DRAWDOWN_PERCENTAGE=0.10

# 每日最大交易次數
MAX_TRADES_PER_DAY=10

# 最低信號置信度（0.65 = 65%）
MIN_SIGNAL_CONFIDENCE=0.65

# ==============================================
# 策略參數
# ==============================================

# RSI 策略
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# 布林帶策略
BOLLINGER_PERIOD=20
BOLLINGER_STD_DEV=2.0

# MACD 策略
MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9
