# BioNeuronAI 環境變數設定
# 複製此文件為 .env 並填入實際值
# 只有以下變數會被程式讀取（透過 os.getenv）

# ==============================================
# Binance API
# 測試網申請: https://testnet.binancefuture.com
# 正式網申請: https://www.binance.com
# ==============================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# true = 測試網（虛擬資金，預設）
# false = 正式網（真實資金）⚠️
BINANCE_TESTNET=true

# ==============================================
# 新聞資料來源
# 免費方案直接填 free，有 token 可填入以提升限制
# 申請: https://cryptopanic.com/developers/api/
# ==============================================
CRYPTOPANIC_API_TOKEN=free
