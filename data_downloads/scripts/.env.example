# Binance 歷史數據下載設定範例
# 複製此文件為 .env 並修改設定

# 數據存放目錄
# Windows 範例: C:\D\E\BioNeuronai\data_downloads\binance_historical
# Linux/Mac 範例: /home/user/BioNeuronai/data_downloads/binance_historical
STORE_DIRECTORY=../binance_historical

# 預設下載設定（可選）
DEFAULT_MARKET_TYPE=um
DEFAULT_SYMBOLS=BTCUSDT ETHUSDT
DEFAULT_INTERVALS=1h 4h
DEFAULT_START_DATE=2023-01-01
